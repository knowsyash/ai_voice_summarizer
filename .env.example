# ============================================
# Echo Archive — Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

# -- Deepgram (Speech-to-Text) --
DEEPGRAM_API_KEY=

# -- OpenAI (Embeddings & Chat) --
OPENAI_API_KEY=

# -- Pinecone (Vector Database) --
PINECONE_API_KEY=
PINECONE_INDEX_NAME=echo-archive

# -- Supabase (Storage & Database) --
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -- Upstash Redis (BullMQ Queue) --
REDIS_URL=

# -- Local ML Service (Free, Open Source) --
ML_SERVICE_URL=http://localhost:8000
WHISPER_MODEL_SIZE=base
SUMMARIZER_MODEL=google/flan-t5-base

# -- Email Agent (Resend) --
# Leave RESEND_API_KEY empty to use draft mode only
RESEND_API_KEY=
EMAIL_FROM=Echo Archive <onboarding@resend.dev>
